# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional: restrict who can use the bot (comma-separated chat IDs).
# Leave empty to allow all chats.
TELEGRAM_ALLOWED_CHAT_IDS=

# Polling and transport
TELEGRAM_POLL_TIMEOUT_SEC=50
TELEGRAM_RETRY_SLEEP_SEC=3
TELEGRAM_LOG_LEVEL=INFO
TELEGRAM_FORCE_IPV4=true

# Search defaults (used by /search and plain fallback flow)
TELEGRAM_SEARCH_LIMIT=5
TELEGRAM_SEMANTIC_DEFAULT=false

# Piper TTS (requires ffmpeg for Telegram-playable voice)
TELEGRAM_PIPER_ENABLED=true
TELEGRAM_PIPER_BIN=piper
TELEGRAM_PIPER_TIMEOUT_SEC=120
TELEGRAM_PIPER_MAX_CHARS=600
TELEGRAM_PIPER_DEFAULT_LANG=en
# Format: lang=/absolute/path/model.onnx,lang2=/absolute/path/model.onnx
TELEGRAM_PIPER_MODELS=

# Codex assistant
TELEGRAM_CODEX_ENABLED=true
TELEGRAM_CODEX_BIN=codex
TELEGRAM_CODEX_MODEL=
TELEGRAM_CODEX_MODE=exec
TELEGRAM_CODEX_THREAD_ID=
TELEGRAM_CODEX_RESUME_FALLBACK_EXEC=false
TELEGRAM_CODEX_TIMEOUT_SEC=120
TELEGRAM_CODEX_INPUT_MAX_CHARS=2500
TELEGRAM_CODEX_REPLY_MAX_CHARS=1400
TELEGRAM_CODEX_WORKDIR=/home/foggen
TELEGRAM_CODEX_SYSTEM_PROMPT=

# tmux relay (send Telegram text into live tmux pane)
TELEGRAM_TMUX_RELAY_ENABLED=true
TELEGRAM_TMUX_TARGET_PANE=main:0.0
TELEGRAM_TMUX_RELAY_MAX_CHARS=2000
TELEGRAM_TMUX_RELAY_PREFIX=[telegram]
TELEGRAM_TMUX_RELAY_ACK=false
TELEGRAM_TMUX_PLAIN_TEXT_TO_TMUX=true

# Plain text reply behavior:
#   silent | quick | codex | quick_codex | session | quick_session
TELEGRAM_PLAIN_TEXT_REPLY_MODE=quick
TELEGRAM_PLAIN_TEXT_QUICK_REPLY="Got it."
TELEGRAM_CODEX_SESSION_REPLY_TIMEOUT_SEC=180
TELEGRAM_CODEX_SESSION_REPLY_WORKERS=4
TELEGRAM_SKIP_BACKLOG_ON_START=false

# Local API for explicit outbound Telegram messages from this machine
TELEGRAM_LOCAL_REPLY_API_ENABLED=true
TELEGRAM_LOCAL_REPLY_API_HOST=127.0.0.1
TELEGRAM_LOCAL_REPLY_API_PORT=8788
TELEGRAM_LOCAL_REPLY_API_TOKEN=
TELEGRAM_LOCAL_REPLY_API_DEDUPE_SEC=10

# Paper Parser API
PAPER_PARSER_API_BASE_URL=http://127.0.0.1:8080
PAPER_PARSER_API_KEY=
