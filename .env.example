# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional: restrict who can use the bot (comma-separated chat IDs)
TELEGRAM_ALLOWED_CHAT_IDS=

# Polling and transport
TELEGRAM_POLL_TIMEOUT_SEC=50
TELEGRAM_RETRY_SLEEP_SEC=3
TELEGRAM_LOG_LEVEL=INFO
TELEGRAM_FORCE_IPV4=true
TELEGRAM_SKIP_BACKLOG_ON_START=false
TELEGRAM_JSON_LOG_ENABLED=true
TELEGRAM_JSON_LOG_PATH=/home/foggen/kitan-telegram/logs/bot.jsonl
TELEGRAM_HEALTH_STATUS_PATH=/home/foggen/kitan-telegram/runtime/health_status.json
TELEGRAM_STATUS_HEALTH_STALE_SEC=1800
TELEGRAM_STATUS_EVENT_LOOKBACK_MIN=15
TELEGRAM_STATUS_EVENT_SCAN_MAX_BYTES=2097152
TELEGRAM_STATUS_QUEUE_PRESSURE_CRITICAL_THRESHOLD=3
TELEGRAM_HEALTH_ALERT_STATE_PATH=/home/foggen/kitan-telegram/runtime/health_alert_state.json
TELEGRAM_HEALTH_ALERT_COOLDOWN_SEC=900
TELEGRAM_HEALTH_ALERT_COOLDOWN_WARNING_SEC=1800
TELEGRAM_HEALTH_ALERT_COOLDOWN_CRITICAL_SEC=900

# Optional: autonomous watcher (idle-based status ping)
YUUKI_WATCHER_ENABLED=false
YUUKI_WATCHER_DRY_RUN=false
YUUKI_WATCHER_REQUIRE_HEALTHY=true
YUUKI_WATCHER_IDLE_SEC=600
YUUKI_WATCHER_COOLDOWN_SEC=3600
YUUKI_WATCHER_STATE_PATH=/home/foggen/kitan-telegram/runtime/watcher_state.json
YUUKI_WATCHER_TASK_STATE_PATH=/home/foggen/AI_github/projects/yuuki-bot-upgrade/LAST_STATE.md

# Optional: periodic self-improve nudge into tmux (simulated [telegram] message)
YUUKI_SELF_IMPROVE_ENABLED=false
YUUKI_SELF_IMPROVE_TARGET_PANE=
YUUKI_SELF_IMPROVE_PREFIX=[telegram]
YUUKI_SELF_IMPROVE_MESSAGE=Продолжай автономный импрувемент: выбери самый полезный следующий шаг, выполни, проверь, и отправь короткий отчёт в Telegram.
YUUKI_SELF_IMPROVE_STATE_PATH=/home/foggen/kitan-telegram/runtime/self_improve_nudge_state.json
YUUKI_SELF_IMPROVE_REQUIRE_HEALTHY=true
YUUKI_SELF_IMPROVE_MIN_INTERVAL_SEC=540
YUUKI_SELF_IMPROVE_NOTIFY_TELEGRAM=true
YUUKI_SELF_IMPROVE_NOTIFY_CHAT_ID=
YUUKI_SELF_IMPROVE_NOTIFY_ON_SKIP=false
YUUKI_SELF_TEST_STATUS_PATH=/home/foggen/kitan-telegram/runtime/self_test_latest.json
YUUKI_SELF_TEST_QUICK_STATUS_PATH=/home/foggen/kitan-telegram/runtime/self_test_quick_latest.json
YUUKI_SELF_TEST_PROFILE=full
YUUKI_SELF_TEST_ONLY=

# tmux relay (plain text -> tmux)
TELEGRAM_TMUX_RELAY_ENABLED=true
TELEGRAM_TMUX_TARGET_PANE=relay:relay.0
TELEGRAM_TMUX_RELAY_MAX_CHARS=2000
TELEGRAM_TMUX_RELAY_PREFIX=[telegram]
TELEGRAM_TMUX_RELAY_ACK=false
TELEGRAM_TMUX_PLAIN_TEXT_TO_TMUX=true
TELEGRAM_TMUX_DEBOUNCE_ENABLED=true
TELEGRAM_TMUX_DEBOUNCE_SEC=3
TELEGRAM_TMUX_PLAIN_TEXT_DEDUPE_ENABLED=true
TELEGRAM_TMUX_PLAIN_TEXT_DEDUPE_SEC=45

# Image intake (photo/image document -> save on VPS + relay path block to tmux)
TELEGRAM_IMAGE_INTAKE_ENABLED=true
TELEGRAM_IMAGE_SAVE_DIR=/tmp/kitan-telegram/images

# File intake (non-image document upload -> save on VPS + relay path block to tmux)
TELEGRAM_FILE_INTAKE_ENABLED=true
TELEGRAM_FILE_SAVE_DIR=/tmp/kitan-telegram/files

# Optional: archive uploaded documents into local AI_github repo + git push
TELEGRAM_AI_ARCHIVE_ENABLED=false
TELEGRAM_AI_ARCHIVE_REPO_DIR=/home/foggen/AI_github
TELEGRAM_AI_ARCHIVE_PUSH=true
TELEGRAM_AI_ARCHIVE_MAX_BYTES=5000000

# Plain text quick ack back to Telegram
TELEGRAM_PLAIN_TEXT_QUICK_REPLY=Got it.

# Piper TTS (requires ffmpeg)
TELEGRAM_PIPER_ENABLED=true
TELEGRAM_PIPER_BIN=piper
TELEGRAM_PIPER_TIMEOUT_SEC=120
TELEGRAM_PIPER_MAX_CHARS=600
TELEGRAM_PIPER_DEFAULT_LANG=en
# Format: lang=/absolute/path/model.onnx,lang2=/absolute/path/model.onnx
TELEGRAM_PIPER_MODELS=

# Local API for explicit outbound Telegram messages
TELEGRAM_LOCAL_REPLY_API_ENABLED=true
TELEGRAM_LOCAL_REPLY_API_HOST=127.0.0.1
TELEGRAM_LOCAL_REPLY_API_PORT=8788
TELEGRAM_LOCAL_REPLY_API_TOKEN=
TELEGRAM_LOCAL_REPLY_API_DEDUPE_SEC=10
TELEGRAM_LOCAL_REPLY_API_SEND_RETRIES=3
TELEGRAM_LOCAL_REPLY_API_SEND_BACKOFF_MS=400
TELEGRAM_LOCAL_REPLY_API_QUEUE_MAX=500
TELEGRAM_LOCAL_REPLY_API_QUEUE_DROP_OLDEST=true
TELEGRAM_LOCAL_REPLY_API_METRICS_STATE_PATH=/home/foggen/kitan-telegram/runtime/reply_api_metrics_state.json

# Optional: explicit chat for health alerts (falls back to first allowed chat id)
TELEGRAM_HEALTH_ALERT_CHAT_ID=
TELEGRAM_ALERT_EVENT_LOOKBACK_MIN=15
TELEGRAM_ALERT_EVENT_SCAN_MAX_BYTES=8388608
TELEGRAM_ALERT_REPLY_FAILED_THRESHOLD=3
TELEGRAM_ALERT_RELAY_ERROR_THRESHOLD=5
TELEGRAM_ALERT_QUEUE_PRESSURE_THRESHOLD=3
TELEGRAM_HEALTH_SELF_TEST_MAX_AGE_SEC=7200
TELEGRAM_HEALTH_REQUIRE_QUICK_SELF_TEST=false
TELEGRAM_HEALTH_QUICK_SELF_TEST_MAX_AGE_SEC=1800
TELEGRAM_HEALTH_SELF_TEST_FAIL_STREAK_THRESHOLD=3
TELEGRAM_HEALTH_SELF_TEST_AUTOREPAIR_ENABLED=true
TELEGRAM_HEALTH_SELF_TEST_AUTOREPAIR_TIMEOUT_SEC=180
TELEGRAM_HEALTH_SELF_TEST_AUTOREPAIR_SCRIPT=/home/foggen/kitan-telegram/scripts/self_test_reliability.sh
